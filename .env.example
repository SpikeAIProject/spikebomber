# =============================================================================
# SPIKE AI - Environment Variables Example
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://spike_user:spike_password@localhost:5432/spike_ai_db?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# =============================================================================
# GOOGLE CLOUD / VERTEX AI
# =============================================================================
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
VERTEX_AI_LOCATION="us-central1"
VERTEX_AI_ENDPOINT=""
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# Gemini API (for direct API access)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-1.5-pro"
GEMINI_FLASH_MODEL="gemini-1.5-flash"

# =============================================================================
# STRIPE BILLING
# =============================================================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# Stripe Price IDs
STRIPE_PRICE_STARTER_MONTHLY="price_starter_monthly_id"
STRIPE_PRICE_PRO_MONTHLY="price_pro_monthly_id"
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_enterprise_monthly_id"
STRIPE_PRICE_STARTER_ANNUAL="price_starter_annual_id"
STRIPE_PRICE_PRO_ANNUAL="price_pro_annual_id"
STRIPE_PRICE_ENTERPRISE_ANNUAL="price_enterprise_annual_id"

# =============================================================================
# NEXT AUTH (Web App)
# =============================================================================
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# APP URLS
# =============================================================================
NEXT_PUBLIC_API_URL="http://localhost:4000/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# =============================================================================
# API SERVER
# =============================================================================
API_PORT=4000
API_HOST="0.0.0.0"
NODE_ENV="development"
API_PREFIX="v1"

# =============================================================================
# ADMIN CREDENTIALS (initial setup)
# =============================================================================
ADMIN_EMAIL="admin@spikeai.io"
ADMIN_PASSWORD="Admin@SecurePassword123!"

# =============================================================================
# SECURITY
# =============================================================================
AES_ENCRYPTION_KEY="your-32-byte-aes-encryption-key-here"
BCRYPT_ROUNDS=12
HMAC_SECRET="your-hmac-secret-for-api-key-signing"

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AI_TTL=60
RATE_LIMIT_AI_MAX=20

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# =============================================================================
# LOGGING / OBSERVABILITY
# =============================================================================
LOG_LEVEL="info"
OTEL_SERVICE_NAME="spike-ai-api"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
SENTRY_DSN=""

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
SMTP_FROM="noreply@spikeai.io"

# =============================================================================
# STORAGE
# =============================================================================
GCS_BUCKET_NAME="spike-ai-uploads"
GCS_BUCKET_REGION="us-central1"

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_MULTIMODAL=true
FEATURE_STREAMING=true
FEATURE_ANALYTICS=true
FEATURE_AUDIT_LOG=true
